# Supabase Configuration
# Create a project at https://supabase.com and copy your credentials
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-or-anon-key

# OpenAI API Key (optional - for AI-powered insights)
# If not provided, the app will use rule-based fallback recommendations
# Do not put private API keys in VITE_ variables; they are exposed to browsers.
VITE_OPENAI_API_KEY=

# App Configuration
VITE_APP_NAME=CarbonWise
